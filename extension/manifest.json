{
  "manifest_version": 3,
  "name": "AI English Learning MVP",
  "description": "Learn English naturally through lightweight contextual replacements on web pages.",
  "version": "0.2.0",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["<all_urls>", "https://api.openai.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "AI English Learning",
    "default_popup": "popup.html"
  },
  "options_page": "app.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/dictionary.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
